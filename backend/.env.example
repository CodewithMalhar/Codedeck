# MongoDB
MONGODB_URI=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/digitomize?ssl=true&replicaSet=atlas-xxx-shard-0&authSource=admin&retryWrites=true&w=majority

# Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
SESSION_SECRET=use-a-long-random-string

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — set after Vercel deploy
FRONTEND_URL=https://your-app.vercel.app
# Optional: comma-separated extra origins
# ALLOWED_ORIGINS=https://www.yourdomain.com
